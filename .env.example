# Copy to .env for local (non-Docker) runs. Docker Compose sets these directly.
# See PRD 15.3.

# --- Backend ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/supportledger
ENVIRONMENT=development
SECRET_KEY=dev-secret-change-me
BACKEND_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Stripe (Phase 4 billing; real key required to use billing/checkout) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# --- LLM (Phase 3 AI Assist; real key required to use AI features) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
