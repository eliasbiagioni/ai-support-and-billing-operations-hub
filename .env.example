# Copy to .env for local (non-Docker) runs. Docker Compose sets these directly.
# See PRD 15.3.

# --- Backend ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/supportledger
ENVIRONMENT=development
SECRET_KEY=dev-secret-change-me
BACKEND_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Stripe (Phase 4 billing; real key required to use billing/checkout) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# --- LLM (Phase 3 AI Assist + Phase 5/6 copilot/RAG; real key required) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
# Embeddings for RAG (Phase 6). Dimension must match EMBEDDING_DIM.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Auth (Phase 7). SECRET_KEY above signs the JWTs. ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Rate limiting (Phase 7; enforced only when ENVIRONMENT=production) ---
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=30/minute

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
